# Azure Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Azure AD B2C
AZURE_AD_B2C_TENANT_NAME=yourtenantname
AZURE_AD_B2C_CLIENT_ID=your-b2c-client-id
AZURE_AD_B2C_CLIENT_SECRET=your-b2c-secret
AZURE_AD_B2C_POLICY_NAME=B2C_1_signupsignin

# Database
SQL_SERVER=your-sql-server.database.windows.net
SQL_DATABASE=sqldb-ecom-dev
SQL_USERNAME=sqladmin
SQL_PASSWORD=use-keyvault

# Key Vault
KEY_VAULT_NAME=kv-ecom-xxxxx

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxxxx

# Server
PORT=3000
NODE_ENV=development